msgstr "IP-adres van de gebruiker bij het registreren van een code."

#: sasoEventtickets_Core.php:272
msgid "User id of the registered user to a code. Default will be 0."
msgstr "Gebruikers-ID van de geregistreerde gebruiker. Standaard is 0."

#: sasoEventtickets_Core.php:273
