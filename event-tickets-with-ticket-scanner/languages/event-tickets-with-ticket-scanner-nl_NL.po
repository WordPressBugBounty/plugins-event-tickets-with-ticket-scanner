#: sasoEventtickets_AdminSettings.php:3246
#, php-format
msgid ""
"WARNING: The ticket number format for list \"%s\" is running out of "
"combinations!\n"
"\n"
"It took %d attempts to generate a ticket code.\n"
"\n"
"Recommended action:\n"
"1. Go to: %s\n"
"2. Edit the ticket list\n"
"3. Consider increasing code length or character set\n"
"\n"
"This is a proactive warning to prevent future issues."
msgstr ""
"WAARSCHUWING: Het ticketnummerformaat voor lijst \"%s\" raakt door de "
"combinaties heen!\n"
"\n"
"Er waren %d pogingen nodig om een ticketcode te genereren.\n"
"\n"
"Aanbevolen actie:\n"
"1. Ga naar: %s\n"
"2. Bewerk de ticketlijst\n"
"3. Overweeg de codelengte of de tekenset te vergroten\n"
"\n"
"Dit is een proactieve waarschuwing om toekomstige problemen te voorkomen."

